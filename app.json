{
  "expo": {
    "name": "NoDrafts Housekeeping",
    "slug": "nodrafts-housekeeping",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "nodrafts-housekeeping",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nodrafts.housekeeping"
    },
    "android": {
      "package": "com.nodrafts.housekeeping"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow NoDrafts Housekeeping to attach photos to incident reports.",
          "cameraPermission": "Allow NoDrafts Housekeeping to take incident photos."
        }
      ]
    ]
  }
}
